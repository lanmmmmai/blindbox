rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isRoomMember(roomCode) {
      return signedIn() &&
        get(/databases/$(database)/documents/rooms/$(roomCode)/players/$(request.auth.uid)).data.hasLeft == false &&
        get(/databases/$(database)/documents/rooms/$(roomCode)/players/$(request.auth.uid)).data.wasRemoved == false;
    }
    match /connection_tests/{uid} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == uid;
    }
    match /rooms/{roomCode} {
      allow read: if isRoomMember(roomCode);
      allow write: if false;
      match /players/{playerUid} { allow read: if isRoomMember(roomCode); allow write: if false; }
      match /boxes/{boxId} { allow read: if isRoomMember(roomCode); allow write: if false; }
      match /actions/{actionId} { allow read: if isRoomMember(roomCode); allow write: if false; }
      match /requests/{requestId} { allow read, write: if false; }
    }
    match /roomSecrets/{secretId} { allow read, write: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
